{
  "name": "junobuild-mcp-server",
  "version": "1.1.1",
  "description": "MCP server for Juno (junobuild) - manage satellites, hosting, functions, snapshots and more",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "junobuild-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nami2111/junobuild-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nami2111/junobuild-mcp/issues"
  },
  "homepage": "https://github.com/nami2111/junobuild-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "juno",
    "junobuild",
    "serverless",
    "internet-computer",
    "satellite",
    "hosting",
    "deploy"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  }
}
